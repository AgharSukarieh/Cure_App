627\u062d",backToSignIn:"\u0627\u0644\u0639\u0648\u062f\u0629 \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644"}},faq:{title:"\u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0634\u0627\u0626\u0639\u0629",welcomeTitle:"\u0645\u0631\u062d\u0628\u0627\u064b \u0628\u0643 \u0641\u064a \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629",welcomeSubtitle:"\u0627\u0628\u062d\u062b \u0639\u0646 \u0625\u062c\u0627\u0628\u0627\u062a \u0644\u0623\u0633\u0626\u0644\u062a\u0643 \u0627\u0644\u0634\u0627\u0626\u0639\u0629",categoriesTitle:"\u0627\u0644\u062a\u0635\u0646\u064a\u0641\u0627\u062a",questionsTitle:"\u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0645\u062a\u0643\u0631\u0631\u0629",questions:"\u0633\u0624\u0627\u0644",needHelp:"\u0647\u0644 \u062a\u062d\u062a\u0627\u062c \u0645\u0633\u0627\u0639\u062f\u0629 \u0625\u0636\u0627\u0641\u064a\u0629\u061f",contactUs:"\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627 \u0648\u0633\u0646\u0643\u0648\u0646 \u0633\u0639\u062f\u0627\u0621 \u0644\u0645\u0633\u0627\u0639\u062f\u062a\u0643",categories:{all:"\u0627\u0644\u0643\u0644",general:"\u0639\u0627\u0645",account:"\u0627\u0644\u062d\u0633\u0627\u0628",orders:"\u0627\u0644\u0637\u0644\u0628\u0627\u062a",payment:"\u0627\u0644\u062f\u0641\u0639",technical:"\u062a\u0642\u0646\u064a"},general:{question1:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u0625\u0646\u0634\u0627\u0621 \u062d\u0633\u0627\u0628 \u062c\u062f\u064a\u062f\u061f",answer1:"\u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u062d\u0633\u0627\u0628 \u062c\u062f\u064a\u062f \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u0649 \u0632\u0631 \"\u0625\u0646\u0634\u0627\u0621 \u062d\u0633\u0627\u0628\" \u0641\u064a \u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644\u060c \u062b\u0645 \u0627\u062a\u0628\u0627\u0639 \u0627\u0644\u062e\u0637\u0648\u0627\u062a \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u0629 \u0644\u0625\u062f\u062e\u0627\u0644 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629.",question2:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0643\u0644\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u061f",answer2:"\u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0643\u0644\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u0649 \"\u0646\u0633\u064a\u062a \u0643\u0644\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\" \u0641\u064a \u0635\u0641\u062d\u0629 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644\u060c \u062b\u0645 \u0627\u062a\u0628\u0627\u0639 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u0627\u062a \u0627\u0644\u0645\u0631\u0633\u0644\u0629 \u0625\u0644\u0649 \u0628\u0631\u064a\u062f\u0643 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a."},account:{question1:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u062a\u062d\u062f\u064a\u062b \u0628\u064a\u0627\u0646\u0627\u062a\u064a \u0627\u0644\u0634\u062e\u0635\u064a\u0629\u061f",answer1:"\u064a\u0645\u0643\u0646\u0643 \u062a\u062d\u062f\u064a\u062b \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0630\u0647\u0627\u0628 \u0625\u0644\u0649 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u062d\u0633\u0627\u0628 \u0648\u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u0629\u060c \u062b\u0645 \u062d\u0641\u0638 \u0627\u0644\u062a\u063a\u064a\u064a\u0631\u0627\u062a.",question2:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u062d\u0630\u0641 \u062d\u0633\u0627\u0628\u064a\u061f",answer2:"\u064a\u0645\u0643\u0646\u0643 \u062d\u0630\u0641 \u062d\u0633\u0627\u0628\u0643 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0630\u0647\u0627\u0628 \u0625\u0644\u0649 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u062d\u0633\u0627\u0628 \u0648\u0627\u062e\u062a\u064a\u0627\u0631 \u062e\u064a\u0627\u0631 \"\u062d\u0630\u0641 \u0627\u0644\u062d\u0633\u0627\u0628\"\u060c \u0645\u0639 \u0627\u0644\u0639\u0644\u0645 \u0623\u0646 \u0647\u0630\u0647 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0644\u0627 \u064a\u0645\u0643\u0646 \u0627\u0644\u062a\u0631\u0627\u062c\u0639 \u0639\u0646\u0647\u0627."},orders:{question1:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u062a\u062a\u0628\u0639 \u0637\u0644\u0628\u064a\u061f",answer1:"\u064a\u0645\u0643\u0646\u0643 \u062a\u062a\u0628\u0639 \u0637\u0644\u0628\u0643 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0630\u0647\u0627\u0628 \u0625\u0644\u0649 \u0642\u0633\u0645 \"\u0637\u0644\u0628\u0627\u062a\u064a\" \u0648\u0627\u062e\u062a\u064a\u0627\u0631 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u060c \u062d\u064a\u062b \u0633\u062a\u062c\u062f \u062a\u0641\u0627\u0635\u064a\u0644 \u062d\u0627\u0644\u0629 \u0627\u0644\u0637\u0644\u0628 \u0648\u0645\u0648\u0642\u0639\u0647 \u0627\u0644\u062d\u0627\u0644\u064a.",question2:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u0625\u0644\u063a\u0627\u0621 \u0637\u0644\u0628\u061f",answer2:"\u064a\u0645\u0643\u0646\u0643 \u0625\u0644\u063a\u0627\u0621 \u0637\u0644\u0628\u0643 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0630\u0647\u0627\u0628 \u0625\u0644\u0649 \u0642\u0633\u0645 \"\u0637\u0644\u0628\u0627\u062a\u064a\" \u0648\u0627\u062e\u062a\u064a\u0627\u0631 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u060c \u062b\u0645 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u0649 \"\u0625\u0644\u063a\u0627\u0621 \u0627\u0644\u0637\u0644\u0628\" \u0625\u0630\u0627 \u0643\u0627\u0646 \u0644\u0627 \u064a\u0632\u0627\u0644 \u0641\u064a \u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u062a\u062d\u0636\u064a\u0631."},payment:{question1:"\u0645\u0627 \u0647\u064a \u0637\u0631\u0642 \u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0645\u062a\u0627\u062d\u0629\u061f",answer1:"\u0646\u062d\u0646 \u0646\u0642\u0628\u0644 \u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0646\u0642\u062f\u064a \u0639\u0646\u062f \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645\u060c \u0648\u0627\u0644\u062f\u0641\u0639 \u0628\u0627\u0644\u0628\u0637\u0627\u0642\u0629 \u0627\u0644\u0627\u0626\u062a\u0645\u0627\u0646\u064a\u0629\u060c \u0648\u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0639\u0628\u0631 \u0627\u0644\u0645\u062d\u0627\u0641\u0638 \u0627\u0644\u0631\u0642\u0645\u064a\u0629.",question2:"\u0647\u0644 \u0627\u0644\u062f\u0641\u0639 \u0622\u0645\u0646\u061f",answer2:"\u0646\u0639\u0645\u060c \u062c\u0645\u064a\u0639 \u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u062f\u0641\u0639 \u0645\u062d\u0645\u064a\u0629 \u0628\u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u062a\u0634\u0641\u064a\u0631 \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629 \u0644\u0636\u0645\u0627\u0646 \u0623\u0645\u0627\u0646 \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0643 \u0627\u0644\u0645\u0627\u0644\u064a\u0629."},technical:{question1:"\u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0644\u0627 \u064a\u0639\u0645\u0644 \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d\u060c \u0645\u0627\u0630\u0627 \u0623\u0641\u0639\u0644\u061f",answer1:"\u062c\u0631\u0628 \u0625\u0639\u0627\u062f\u0629 \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0623\u0648\u0644\u0627\u064b\u060c \u0648\u0625\u0630\u0627 \u0627\u0633\u062a\u0645\u0631\u062a \u0627\u0644\u0645\u0634\u0643\u0644\u0629\u060c \u062a\u0623\u0643\u062f \u0645\u0646 \u062a\u062d\u062f\u064a\u062b \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0625\u0644\u0649 \u0623\u062d\u062f\u062b \u0625\u0635\u062f\u0627\u0631\u060c \u0623\u0648 \u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0641\u0631\u064a\u0642 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0641\u0646\u064a.",question2:"\u0643\u064a\u0641 \u064a\u0645\u0643\u0646\u0646\u064a \u062a\u062d\u062f\u064a\u062b \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u061f",answer2:"\u064a\u0645\u0643\u0646\u0643 \u062a\u062d\u062f\u064a\u062b \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0645\u062a\u062c\u0631 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0627\u062a (App Store \u0623\u0648 Google Play) \u0648\u0627\u0644\u0628\u062d\u062b \u0639\u0646 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u060c \u062b\u0645 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u0649 \"\u062a\u062d\u062f\u064a\u062b\" \u0625\u0630\u0627 \u0643\u0627\u0646 \u0645\u062a\u0627\u062d\u0627\u064b."}},reportsScreen:{header:"\u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631",selectCity:"\u0627\u062e\u062a\u0631 \u0627\u0644\u0645\u062f\u064a\u0646\u0629",selectArea:"\u0627\u062e\u062a\u0631 \u0627\u0644\u0645\u0646\u0637\u0642\u0629",from:"\u0645\u0646",to:"\u0625\u0644\u0649",selectStartDate:"\u0627\u062e\u062a\u0631 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0628\u062f\u0627\u064a\u0629",selectEndDate:"\u0627\u062e\u062a\u0631 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0646\u0647\u0627\u064a\u0629",filters:{selectCity:"\u0627\u062e\u062a\u0631 \u0627\u0644\u0645\u062f\u064a\u0646\u0629",selectArea:"\u0627\u062e\u062a\u0631 \u0627\u0644\u0645\u0646\u0637\u0642\u0629",from:"\u0645\u0646",to:"\u0625\u0644\u0649"},table:{name:"\u0627\u0644\u0627\u0633\u0645",target:"\u0627\u0644\u0647\u062f\u0641",achievement:"\u0627\u0644\u0625\u0646\u062c\u0627\u0632",region:"\u0627\u0644\u0645\u0646\u0637\u0642\u0629",performance:"\u0627\u0644\u0623\u062f\u0627\u0621",bonus:"\u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629"},achievementStatus:{achieved:"\u062a\u0645 \u0627\u0644\u0625\u0646\u062c\u0627\u0632",exceeded:"\u062a\u062c\u0627\u0648\u0632 \u0627\u0644\u0647\u0
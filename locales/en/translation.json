    "general": {
      "question1": "How can I create a new account?",
      "answer1": "You can create a new account by clicking the \"Create Account\" button on the login page, then follow the required steps to enter your personal information.",
      "question2": "How can I reset my password?",
      "answer2": "You can reset your password by clicking \"Forgot Password\" on the login page, then follow the instructions sent to your email."
    },
    "account": {
      "question1": "How can I update my personal information?",
      "answer1": "You can update your personal information by going to account settings and modifying the required information, then save the changes.",
      "question2": "How can I delete my account?",
      "answer2": "You can delete your account by going to account settings and selecting \"Delete Account\" option, keeping in mind that this action cannot be undone."
    },
    "orders": {
      "question1": "How can I track my order?",
      "answer1": "You can track your order by going to \"My Orders\" section and selecting the desired order, where you'll find order status details and current location.",
      "question2": "How can I cancel an order?",
      "answer2": "You can cancel your order by going to \"My Orders\" section and selecting the desired order, then clicking \"Cancel Order\" if it's still in preparation stage."
    },
    "payment": {
      "question1": "What payment methods are available?",
      "answer1": "We accept cash on delivery, credit card payment, and electronic payment through digital wallets.",
      "question2": "Is payment secure?",
      "answer2": "Yes, all payment transactions are protected with advanced encryption technologies to ensure the security of your financial information."
    },
    "technical": {
      "question1": "The app is not working properly, what should I do?",
      "answer1": "Try restarting the app first, and if the problem persists, make sure to update the app to the latest version, or contact our technical support team.",
      "question2": "How can I update the app?",
      "answer2": "You can update the app through the app store (App Store or Google Play) and search for the app, then click \"Update\" if available."
    }
